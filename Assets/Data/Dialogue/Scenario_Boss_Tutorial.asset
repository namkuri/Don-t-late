  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a5e3ef5ec1efc4b4397e1c503ec59084, type: 3}
  m_Name: Scenario_Boss_Tutorial
  m_EditorClassIdentifier: Assembly-CSharp::DontLate.DialogueScenarioSO
  lines:
  - speaker: "\uC0AC\uC7A5\uB2D8"
    text: "\uC5B4\uC774 \uC2E0\uC785! \uC654\uAD6C\uBA3C. \uC5EC\uAE30\uAC00 \uBB3C\uB958\uCEA0\uD504\uC57C."
    portrait: {fileID: 0}
  - speaker: "\uC0AC\uC7A5\uB2D8"
    text: "\uC800\uAE30 \uAC8C\uC2DC\uD310\uC5D0\uC11C \uC624\uB298 \uC8FC\uBB38
      \uBC1B\uACE0, \uC0C1\uC790\uB294 \uBC14\uCF54\uB4DC \uC2A4\uCE94\uBD80\uD130
      \uD574. \uC2A4\uCE94 \uC548 \uD55C \uC9D0\uC740 \uBABB \uC2E4\uC5B4."
    portrait: {fileID: 0}
  - speaker: "\uC0AC\uC7A5\uB2D8"
    text: "\uC2A4\uCE94\uD55C \uC0C1\uC790\uB294 \uD2B8\uB7ED\uC5D0 \uC2E4\uC73C\uBA74
      \uB418\uACE0, \uBB34\uAC70\uC6B0\uBA74 \uB300\uCC28\uC5D0 \uBC00\uC5B4 \uB2F4\uC544\uC11C
      \uC62E\uACA8."
    portrait: {fileID: 0}
  - speaker: "\uC0AC\uC7A5\uB2D8"
    text: "\uB9C8\uAC10 \uC2DC\uAC04 \uB118\uAE30\uBA74 \uBC8C\uAE08\uC774\uC57C.
      \uB2A6\uC9C0 \uB9C8 \u2014 \uADF8\uAC8C \uC774 \uBC14\uB2E5 \uC81C1\uC6D0\uCE59\uC774\uB2E4."
    portrait: {fileID: 0}
  - speaker: "\uC0AC\uC7A5\uB2D8"
    text: "\uB2E4 \uC2E4\uC5C8\uC73C\uBA74 \uCD9C\uBC1C\uD574. \uD654\uC774\uD305\uC774\uC57C,
      \uC2E0\uC785!"
    portrait: {fileID: 0}
