  - speaker: "\uBC15\uB9D0\uC21C"
    text: "\uB2E4\uC74C \uAC74 \uB6F0\uC5B4. \uBB34\uB98E\uC774 \uAC08\uB9AC\uB3C4\uB85D
      \uB6F0\uC5B4!"
    portrait: {fileID: 0}
  - speaker: "\uC8FC\uC778\uACF5"
    text: "(\u2026\uBE5A\uC774 \uB610 \uB298\uC5C8\uB2E4.)"
