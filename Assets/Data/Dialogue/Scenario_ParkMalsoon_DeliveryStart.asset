  lines:
  - speaker: "\uBC15\uB9D0\uC21C"
    text: "\uC0C1\uC790\uB294 \uB450 \uC190\uC73C\uB85C! \uB358\uC9C0\uB294 \uAC70
      \uB2E4 \uBCF4\uC5EC, \uCD1D\uAC01."
    portrait: {fileID: 0}
  - speaker: "\uBC15\uB9D0\uC21C"
    text: "'\uCDE8\uAE09\uC8FC\uC758' \uBD99\uC740 \uAC74 \uC9C4\uC9DC \uCDE8\uAE09\uC8FC\uC758\uC57C.
      \uAE68\uC9C0\uBA74 \uB124 \uBE5A."
    portrait: {fileID: 0}
  - speaker: "\uBC15\uB9D0\uC21C"
    text: "\uC2DC\uACC4 \uBD10. \uB9C8\uAC10 \uB118\uAE30\uBA74 \uC54C\uC9C0? \uB2A6\uC9C0\uB9C8!"
    portrait: {fileID: 0}
